# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# superpowers brainstorm mockups (local design artifacts)
.superpowers/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit real secrets; .env.example is a safe placeholder template
.env*
!.env.example

# vercel
.vercel

# claude code (machine-local permissions + runtime artifacts; the dir itself stays trackable for shared config)
.claude/settings.local.json
.claude/*.lock

# typescript
*.tsbuildinfo
next-env.d.ts

# tool artifacts
.gstack/
.hallmark/
