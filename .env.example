# ── Database (three Neon roles) ───────────────────────────────────────────────
# Local/CI: OWNER role string — runs migrations + seed (break-glass).
# In Vercel: set this to the APP role string instead (read/write incl. auth tables, NOT owner).
DATABASE_URL=

# Scoped AGENT role — CLI + agents only. read/write on projects+tasks+runs+events, no auth tables.
# NEVER set this in Vercel. Required: cc refuses to run (exit 4) on DATABASE_URL alone unless
# CC_ALLOW_DATABASE_URL_FALLBACK=1 (no silent owner-role fallback).
AGENT_DATABASE_URL=

# Tip: for local dev, point the two vars above at a Neon `dev` branch (isolated from prod),
# and keep prod's strings as a commented pair you swap in when you need them. Create the branch:
#   console.neon.tech → Branches → Create → name `dev`, parent `main`, current PIT.
# Roles + passwords are inherited from main, so only the host differs from prod.

# ── Auth (BetterAuth) ─────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=                      # strong unique random; app throws if missing
BETTER_AUTH_URL=http://localhost:3000    # set to the prod origin in Vercel Production
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (Cloud Console). Authorized redirect URIs must include:
#   http://localhost:3000/api/auth/callback/google   (dev)
#   https://<your-prod-domain>/api/auth/callback/google   (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Allowlist: only this email may sign in. Fail-closed: empty => reject everyone.
ALLOWED_EMAIL=you@example.com

# ── Mission Control (Phase 1) ─────────────────────────────────────────────────
# Bearer secret for the telemetry ingest endpoint (/api/ingest). Claude Code hooks send
# `Authorization: Bearer $INGEST_TOKEN`. Write-only; separate from BetterAuth. Set in Vercel too.
INGEST_TOKEN=
# Bearer secret Vercel Cron sends to the reaper (/api/cron/reap) so it isn't publicly triggerable.
CRON_SECRET=

# GitHub fine-grained token — Contents: Read — for the Commits tab on project detail pages.
# Create at https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=

# Sentry — powers the project "Errors" tab (live unresolved issues).
# Token needs the project:read scope. SENTRY_BASE_URL is optional (region/self-hosted).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_BASE_URL=https://sentry.io

# Local-part shown for Zoho-email integration rows in the grid (renders <localpart>@<domain>).
# Defaults to "info" if unset.
ZOHO_EMAIL_LOCALPART=
